{
  "name": "Java",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.m2",
      "target": "/home/vscode/.m2"
    },
  ],

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "25.r25-nik",
      "installMaven": "false",
      "installGradle": "false"
    }
  }
}
